{
	"manifest_version": 3,
	"name": "Direct Link Extractor",
	"version": "1.0.1",
	"description": "Extracts and generates direct download links for fuckingfast.co and datanodes.to.",
	"permissions": ["storage", "cookies", "activeTab", "scripting"],
	"host_permissions": ["https://fuckingfast.co/*", "https://datanodes.to/*"],
	"browser_specific_settings": {
		"gecko": {
			"id": "direct-link-extractor@TH3-AZ.com",
			"strict_min_version": "140.0",
			"data_collection_permissions": {
				"required": ["none"]
			}
		}
	},
	"background": {
		"service_worker": "background.js",
		"scripts": ["background.js"]
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"],
			"run_at": "document_start"
		}
	],
	"options_ui": {
		"page": "popup.html",
		"open_in_tab": true
	},
	"web_accessible_resources": [
		{
			"resources": ["assets/img/icon.*"],
			"matches": ["<all_urls>"]
		}
	],
	"action": {
		"default_popup": "popup.html",
		"default_title": "Direct Link Extractor",
		"default_icon": {
			"16": "assets/img/icon.16.png",
			"32": "assets/img/icon.32.png",
			"48": "assets/img/icon.48.png",
			"128": "assets/img/icon.128.png"
		}
	},
	"icons": {
		"16": "assets/img/icon.16.png",
		"32": "assets/img/icon.32.png",
		"48": "assets/img/icon.48.png",
		"128": "assets/img/icon.128.png"
	}
}
